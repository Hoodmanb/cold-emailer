# ── E2E Test Environment Variables ────────────────────────────────────────────
# Copy this file to .env.test.local and fill in real values.
# DO NOT commit real credentials to version control.

# ── Frontend URL ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# Required for scheduler E2E tests (also set when starting the frontend dev server)
NEXT_PUBLIC_SCHEDULER_ENABLED=true

# ── Backend API URL ───────────────────────────────────────────────────────────
API_BASE_URL=http://localhost:9000

# ── Regular Test User ─────────────────────────────────────────────────────────
# Must exist in Supabase with a confirmed account
E2E_USER_EMAIL=e2e-user@careerbot.test
E2E_USER_PASSWORD=E2eTestPassword123!
# Bearer token for direct API tests (obtain by logging in and copying token)
E2E_USER_TOKEN=

# ── Admin Test User ───────────────────────────────────────────────────────────
# Must be the ADMIN_EMAIL set in server/.env, with admin role
E2E_ADMIN_EMAIL=joshuadebravo@gmail.com
E2E_ADMIN_PASSWORD=
# Bearer token for admin API tests
E2E_ADMIN_TOKEN=

# ── SMTP Test Config (for SMTP connection test) ───────────────────────────────
E2E_SMTP_USER=
E2E_SMTP_PASS=

# ── CI/CD Flags ───────────────────────────────────────────────────────────────
CI=false
