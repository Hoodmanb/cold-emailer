# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from your Supabase project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── OpenRouter AI Gateway ───────────────────────────────────────────────────
OPENROUTER_API_KEY=

# ─── Crypto / Encryption ─────────────────────────────────────────────────────
# Used for encrypting stored SMTP passwords
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRYPTO_SECRET_KEY=

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=9000
NODE_ENV=development
LOG_LEVEL=medium

# ─── Paystack Billing ────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_CALLBACK_URL=http://localhost:3000/dashboard/billing

# ─── Admin ────────────────────────────────────────────────────────────────────
# User with this email gets admin role on server boot
ADMIN_EMAIL=example@gmail.com

# ─── System AI ───────────────────────────────────────────────────────────────
SYSTEM_AI_PROVIDER=openrouter
SYSTEM_AI_MODEL=openai/gpt-4o-mini

# ─── Frontend / App URLs ─────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:9000
# Used for Supabase password-reset redirect and other absolute URLs
APP_URL=http://localhost:9000

# ─── QStash Scheduler ────────────────────────────────────────────────────────
SCHEDULER_ENABLED=false
QSTASH_TOKEN=
QSTASH_URL=https://qstash.upstash.io
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
