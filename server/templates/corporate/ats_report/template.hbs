{{#> layout/base_document title="ATS Match Report" }}
<div class="report-wrapper">
  
  <header class="report-header">
    <h1>ATS Match Analysis</h1>
    <div class="subtitle">Generated by Career AI Platform</div>
  </header>

  <div class="score-card avoid-break-inside">
    <div class="score-circle {{scoreClass}}">
      <span class="score-num">{{score}}</span>
      <span class="score-label">/ 100</span>
    </div>
    <div class="breakdown">
      <div class="bar-row">
        <div class="bar-label"><span>Technical Match</span><span>{{breakdown.technicalSkills}}%</span></div>
        <div class="bar-track"><div class="bar-fill" style="width:{{breakdown.technicalSkills}}%"></div></div>
      </div>
      <div class="bar-row">
        <div class="bar-label"><span>Keyword Density</span><span>{{breakdown.keywordMatch}}%</span></div>
        <div class="bar-track"><div class="bar-fill" style="width:{{breakdown.keywordMatch}}%"></div></div>
      </div>
      <div class="bar-row">
        <div class="bar-label"><span>Soft Skills</span><span>{{breakdown.softSkills}}%</span></div>
        <div class="bar-track"><div class="bar-fill" style="width:{{breakdown.softSkills}}%"></div></div>
      </div>
    </div>
  </div>

  {{#if matchedKeywords.length}}
  <section class="section avoid-break-inside">
    <h2 class="section-title">Optimized Keywords</h2>
    <div class="tags-container">
      {{#each matchedKeywords}}<span class="tag tag-matched">{{this}}</span>{{/each}}
    </div>
  </section>
  {{/if}}

  {{#if missingKeywords.length}}
  <section class="section avoid-break-inside">
    <h2 class="section-title">Missing Keywords to Target</h2>
    <div class="tags-container">
      {{#each missingKeywords}}<span class="tag tag-missing">{{this}}</span>{{/each}}
    </div>
  </section>
  {{/if}}

  {{#if recommendation}}
  <section class="section avoid-break-inside">
    <div class="recommendation-box">
      <strong>Strategic Recommendation:</strong> {{recommendation}}
    </div>
  </section>
  {{/if}}

</div>
{{/layout/base_document}}
