{{#> layout/base_document title=projectName }}
<div class="summary-wrapper">
  
  <header class="summary-header">
    <h1 class="project-title">{{projectName}}</h1>
    <div class="project-meta">
      <span class="role">{{role}}</span>
      <span class="duration">{{duration}}</span>
    </div>
  </header>

  <div class="summary-grid">
    <div class="main-column">
      <section class="section avoid-break-inside">
        <h2 class="section-title">Project Overview</h2>
        <p>{{overview}}</p>
      </section>

      {{#if challenges.length}}
      <section class="section avoid-break-inside">
        <h2 class="section-title">Key Challenges</h2>
        <ul class="bullet-list">
          {{#each challenges}}
            <li>{{this}}</li>
          {{/each}}
        </ul>
      </section>
      {{/if}}

      {{#if solutions.length}}
      <section class="section avoid-break-inside">
        <h2 class="section-title">Solutions Implemented</h2>
        <ul class="bullet-list">
          {{#each solutions}}
            <li>{{this}}</li>
          {{/each}}
        </ul>
      </section>
      {{/if}}

      {{#if outcomes.length}}
      <section class="section avoid-break-inside">
        <h2 class="section-title">Impact & Outcomes</h2>
        <ul class="bullet-list highlight-list">
          {{#each outcomes}}
            <li>{{this}}</li>
          {{/each}}
        </ul>
      </section>
      {{/if}}
    </div>

    <div class="side-column">
      {{#if technologies.length}}
      <section class="section avoid-break-inside">
        <h2 class="section-title">Technologies</h2>
        <div class="tech-grid">
          {{#each technologies}}
            <span class="tech-badge">{{this}}</span>
          {{/each}}
        </div>
      </section>
      {{/if}}
    </div>
  </div>

</div>
{{/layout/base_document}}
