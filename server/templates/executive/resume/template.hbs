{{#> layout/base_document title=(concat contact.name " - Resume") }}
<div class="resume-wrapper">
  
  <header class="resume-header">
    <div class="header-inner">
      <h1>{{contact.name}}</h1>
      <div class="contact-info">
        {{#if contact.email}}<span>{{contact.email}}</span>{{/if}}
        {{#if contact.phone}}<span>{{contact.phone}}</span>{{/if}}
        {{#if contact.location}}<span>{{contact.location}}</span>{{/if}}
        {{#if contact.linkedin}}<span>{{contact.linkedin}}</span>{{/if}}
      </div>
    </div>
  </header>

  <div class="resume-content">
    {{#if summary}}
    <section class="section summary-section">
      <h2 class="section-title">Executive Summary</h2>
      <p>{{summary}}</p>
    </section>
    {{/if}}

    {{#if experience.length}}
    <section class="section exp-section">
      <h2 class="section-title">Career History</h2>
      {{#each experience}}
        {{> sections/experience_block this}}
      {{/each}}
    </section>
    {{/if}}

    <div class="two-col-layout">
      {{#if education.length}}
      <section class="section edu-section">
        <h2 class="section-title">Education</h2>
        {{#each education}}
          {{> sections/education_block this}}
        {{/each}}
      </section>
      {{/if}}

      {{#if skills.length}}
      <section class="section skills-section">
        <h2 class="section-title">Core Expertise</h2>
        <div class="skills-list">
          {{#each skills}}
            <span class="skill-item">{{this}}</span>
          {{/each}}
        </div>
      </section>
      {{/if}}
    </div>
  </div>

</div>
{{/layout/base_document}}
