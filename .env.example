# OpenRouter AI Gateway
OPENROUTER_API_KEY=

# Gmail App Password Encryption (generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
CRYPTO_SECRET_KEY=

# Server
PORT=9000
NODE_ENV=development
LOG_LEVEL=medium

# Frontend (copy to cold-emailer/fe/.env.local)
NEXT_PUBLIC_API_URL=http://localhost:3001
